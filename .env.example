# Copy this file to `.env` and fill in the values you need.
# `.env` is git-ignored. Values defined here are loaded automatically by
# spatial_agent.config.get_config() and can be referenced from any model
# config JSON via ${VAR_NAME} expansion.
#
# Environment variables already set in the shell take precedence over .env.

# --- LLM API keys ---
# Used by model configs (config/model/*.json) whose "llm_base_url" points at a
# hosted OpenAI-compatible endpoint and whose "llm_api_key" is
# "${NVIDIA_API_KEY}". The shipped configs all use self-hosted vLLM
# ("llm_api_key": "bearer") and don't need this.
NVIDIA_API_KEY=

# Used as a fallback by the LLM client if `llm_api_key` resolves to an empty
# string (e.g. when a model config references ${OPENAI_API_KEY} or you set
# llm_api_key to "${OPENAI_API_KEY:-bearer}" in a custom config).
OPENAI_API_KEY=

# --- HuggingFace ---
# Required for gated repos (SAM3.1) during model download.
# HF_TOKEN=

# --- Optional: override any SpatialAgentConfig field ---
# Any dataclass field on SpatialAgentConfig can be overridden via
# SPATIAL_AGENT_<FIELD_NAME>=value. Examples:
# SPATIAL_AGENT_BENCHMARK=erqa
# SPATIAL_AGENT_CONCURRENCY=8
